# ─────────────────────────────────────────────────────────────
# Prana House — Environment Variables (template)
# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env file.
# ─────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Prana House <hello@yourdomain.com>
ADMIN_EMAIL=you@example.com

# Admin login (REQUIRED — login is disabled if ADMIN_PASSWORD is empty)
# Use a long, unique password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session secret — signs admin tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=generate-a-long-random-string

# Optional
PORT=3000
